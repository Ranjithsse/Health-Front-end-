<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <!-- 1. Header Toolbar (Blue) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="@color/primary_blue"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_back_arrow"
            android:contentDescription="Back"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/white" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="Medical Imaging"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@+id/btnBack"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- 2. Viewer Title Bar (Dark) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/viewerControlBar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#111827"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toBottomOf="@+id/toolbar">

        <TextView
            android:id="@+id/tvViewerTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Medical Imaging Viewer (Axial)"
            android:textColor="@color/white"
            android:textSize="16sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- 3. Viewer Content Area (Pure Black) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/viewerArea"
        android:layout_width="match_parent"
        android:layout_height="320dp"
        android:background="#000000"
        app:layout_constraintTop_toBottomOf="@+id/viewerControlBar">

        <!-- Medical Image View -->
        <ImageView
            android:id="@+id/ivDicomImage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitCenter"
            android:alpha="1.0"
            android:visibility="visible" />

        <!-- Overlay Visuals (Crosshairs and Focus) -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/mockupVisuals"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/focusCircle"
                android:layout_width="280dp"
                android:layout_height="280dp"
                app:cardBackgroundColor="#00000000"
                app:cardCornerRadius="140dp"
                app:cardElevation="0dp"
                app:strokeColor="#3B82F6"
                app:strokeWidth="1.5dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <View
                        android:id="@+id/crosshairH"
                        android:layout_width="match_parent"
                        android:layout_height="1.5dp"
                        android:background="#3B82F6"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <View
                        android:id="@+id/crosshairV"
                        android:layout_width="1.5dp"
                        android:layout_height="match_parent"
                        android:background="#3B82F6"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent" />

                    <TextView
                        android:id="@+id/tvSliceLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="DICOM Render"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:alpha="0.8"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Dynamic Slice Slider (Pill Shape) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/sliderContainer"
            android:layout_width="36dp"
            android:layout_height="220dp"
            android:layout_marginEnd="16dp"
            app:cardBackgroundColor="#1F2937"
            app:cardCornerRadius="18dp"
            app:cardElevation="0dp"
            app:strokeColor="#374151"
            app:strokeWidth="1dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <View
                    android:layout_width="4dp"
                    android:layout_height="match_parent"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginVertical="24dp"
                    android:background="#374151" />

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/sliderThumb"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="center"
                    app:cardBackgroundColor="#3B82F6"
                    app:cardCornerRadius="10dp"
                    app:cardElevation="4dp"
                    app:strokeColor="#60A5FA"
                    app:strokeWidth="1dp" />
            </FrameLayout>
        </com.google.android.material.card.MaterialCardView>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- 4. Tab Selector (Dark Background) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/tabSelectionBar"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:background="#111827"
        android:paddingHorizontal="12dp"
        app:layout_constraintTop_toBottomOf="@+id/viewerArea">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardAxial"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_marginHorizontal="8dp"
            app:cardBackgroundColor="@color/primary_blue"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            android:clickable="true"
            android:focusable="true"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/cardSagittal"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">
            <TextView
                android:id="@+id/tvAxial"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="Axial"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold" />
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardSagittal"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_marginHorizontal="8dp"
            app:cardBackgroundColor="@android:color/transparent"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            android:clickable="true"
            android:focusable="true"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/cardCoronal"
            app:layout_constraintStart_toEndOf="@+id/cardAxial"
            app:layout_constraintTop_toTopOf="parent">
            <TextView
                android:id="@+id/tvSagittal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="Sagittal"
                android:textColor="@color/white"
                android:textSize="14sp" />
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardCoronal"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_marginHorizontal="8dp"
            app:cardBackgroundColor="@android:color/transparent"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            android:clickable="true"
            android:focusable="true"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/cardSagittal"
            app:layout_constraintTop_toTopOf="parent">
            <TextView
                android:id="@+id/tvCoronal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="Coronal"
                android:textColor="@color/white"
                android:textSize="14sp" />
        </com.google.android.material.card.MaterialCardView>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- 5. Bottom Action Area (White Background) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/bottomActionArea"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="#FFFFFF"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tabSelectionBar">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnExtractTissue"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="20dp"
            android:text="Extract Tissue Data"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:textStyle="bold"
            app:backgroundTint="@color/primary_blue"
            app:cornerRadius="12dp"
            app:layout_constraintTop_toTopOf="parent"
            android:letterSpacing="0"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
