<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC">

    <!-- Header Toolbar -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="#1D4ED8"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_back_arrow"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/white"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:text="AI Prediction"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@+id/btnBack"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="40dp">

            <!-- Title Section -->
            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="Why this prediction?"
                android:textColor="#0F172A"
                android:textSize="22sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tvSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="SHAP Feature Importance"
                android:textColor="#94A3B8"
                android:textSize="16sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvTitle" />

            <!-- Feature Contribution Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardChart"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="32dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeColor="#E2E8F0"
                app:strokeWidth="1dp"
                app:layout_constraintTop_toBottomOf="@id/tvSubtitle">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingHorizontal="24dp"
                        android:paddingTop="24dp"
                        android:paddingBottom="16dp"
                        android:text="Feature Contribution"
                        android:textColor="#0F172A"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#F1F5F9" />

                    <!-- Custom Bar Chart Area -->
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="32dp">

                        <!-- Guidelines based on SVG coordinates (width 311) -->
                        <androidx.constraintlayout.widget.Guideline
                            android:id="@+id/guideSolidLine"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            app:layout_constraintGuide_percent="0.27" />

                        <androidx.constraintlayout.widget.Guideline
                            android:id="@+id/guideBase"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            app:layout_constraintGuide_percent="0.45" />

                        <androidx.constraintlayout.widget.Guideline
                            android:id="@+id/guideGrid2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            app:layout_constraintGuide_percent="0.63" />

                        <androidx.constraintlayout.widget.Guideline
                            android:id="@+id/guideGrid3"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            app:layout_constraintGuide_percent="0.80" />

                        <androidx.constraintlayout.widget.Guideline
                            android:id="@+id/guideGrid4"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            app:layout_constraintGuide_percent="0.98" />

                        <!-- Dashed Grid Lines -->
                        <View android:id="@+id/vGrid1" android:layout_width="1dp" android:layout_height="0dp" android:background="@drawable/dash_line" app:layout_constraintBottom_toBottomOf="@+id/barActivity" app:layout_constraintStart_toStartOf="@id/guideSolidLine" app:layout_constraintTop_toTopOf="@+id/barBp" />
                        <View android:id="@+id/vGrid2" android:layout_width="1dp" android:layout_height="0dp" android:background="@drawable/dash_line" app:layout_constraintBottom_toBottomOf="@+id/barActivity" app:layout_constraintStart_toStartOf="@id/guideBase" app:layout_constraintTop_toTopOf="@+id/barBp" />
                        <View android:id="@+id/vGrid3" android:layout_width="1dp" android:layout_height="0dp" android:background="@drawable/dash_line" app:layout_constraintBottom_toBottomOf="@+id/barActivity" app:layout_constraintStart_toStartOf="@id/guideGrid2" app:layout_constraintTop_toTopOf="@+id/barBp" />
                        <View android:id="@+id/vGrid4" android:layout_width="1dp" android:layout_height="0dp" android:background="@drawable/dash_line" app:layout_constraintBottom_toBottomOf="@+id/barActivity" app:layout_constraintStart_toStartOf="@id/guideGrid3" app:layout_constraintTop_toTopOf="@+id/barBp" />
                        <View android:id="@+id/vGrid5" android:layout_width="1dp" android:layout_height="0dp" android:background="@drawable/dash_line" app:layout_constraintBottom_toBottomOf="@+id/barActivity" app:layout_constraintStart_toStartOf="@id/guideGrid4" app:layout_constraintTop_toTopOf="@+id/barBp" />

                        <!-- Solid Vertical Axis Line -->
                        <View
                            android:id="@+id/solidYAxis"
                            android:layout_width="1.5dp"
                            android:layout_height="0dp"
                            android:background="#666666"
                            app:layout_constraintBottom_toBottomOf="@+id/barActivity"
                            app:layout_constraintStart_toStartOf="@id/guideSolidLine"
                            app:layout_constraintTop_toTopOf="@+id/barBp"
                            android:layout_marginTop="-8dp"
                            android:layout_marginBottom="-8dp" />

                        <!-- 1. Blood Pressure -->
                        <View android:id="@+id/tickBp" android:layout_width="6dp" android:layout_height="1dp" android:background="#666666" app:layout_constraintBottom_toBottomOf="@id/barBp" app:layout_constraintEnd_toEndOf="@id/guideSolidLine" app:layout_constraintTop_toTopOf="@id/barBp" />
                        <TextView
                            android:id="@+id/labelBp"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="10dp"
                            android:gravity="end"
                            android:text="Blood\nPressure"
                            android:textColor="#666666"
                            android:textSize="12sp"
                            android:lineSpacingMultiplier="0.85"
                            app:layout_constraintBottom_toBottomOf="@+id/barBp"
                            app:layout_constraintEnd_toStartOf="@id/tickBp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="@+id/barBp" />
                        <View
                            android:id="@+id/barBp"
                            android:layout_width="0dp"
                            android:layout_height="40dp"
                            android:background="#1976D2"
                            app:layout_constraintStart_toStartOf="@id/guideBase"
                            app:layout_constraintEnd_toEndOf="@id/guideGrid3"
                            app:layout_constraintTop_toTopOf="parent"
                            android:layout_marginEnd="3dp"/>

                        <!-- 2. Cholesterol -->
                        <View android:id="@+id/tickChol" android:layout_width="6dp" android:layout_height="1dp" android:background="#666666" app:layout_constraintBottom_toBottomOf="@id/barChol" app:layout_constraintEnd_toEndOf="@id/guideSolidLine" app:layout_constraintTop_toTopOf="@id/barChol" />
                        <TextView
                            android:id="@+id/labelChol"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="10dp"
                            android:gravity="end"
                            android:text="Cholesterol"
                            android:textColor="#666666"
                            android:textSize="12sp"
                            app:layout_constraintBottom_toBottomOf="@+id/barChol"
                            app:layout_constraintEnd_toStartOf="@id/tickChol"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="@+id/barChol" />
                        <View
                            android:id="@+id/barChol"
                            android:layout_width="0dp"
                            android:layout_height="40dp"
                            android:layout_marginTop="12dp"
                            android:background="#1976D2"
                            app:layout_constraintStart_toStartOf="@id/guideBase"
                            app:layout_constraintEnd_toEndOf="@id/guideGrid2"
                            app:layout_constraintTop_toBottomOf="@id/barBp"
                            android:layout_marginEnd="25dp"/>

                        <!-- 3. Smoking -->
                        <View android:id="@+id/tickSmoking" android:layout_width="6dp" android:layout_height="1dp" android:background="#666666" app:layout_constraintBottom_toBottomOf="@id/barSmoking" app:layout_constraintEnd_toEndOf="@id/guideSolidLine" app:layout_constraintTop_toTopOf="@id/barSmoking" />
                        <TextView
                            android:id="@+id/labelSmoking"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="10dp"
                            android:gravity="end"
                            android:text="Smoking"
                            android:textColor="#666666"
                            android:textSize="12sp"
                            app:layout_constraintBottom_toBottomOf="@+id/barSmoking"
                            app:layout_constraintEnd_toStartOf="@id/tickSmoking"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="@+id/barSmoking" />
                        <View
                            android:id="@+id/barSmoking"
                            android:layout_width="0dp"
                            android:layout_height="40dp"
                            android:layout_marginTop="12dp"
                            android:background="#1976D2"
                            app:layout_constraintEnd_toStartOf="@id/guideBase"
                            app:layout_constraintStart_toStartOf="@id/guideSolidLine"
                            app:layout_constraintTop_toBottomOf="@id/barChol"
                            android:layout_marginStart="4dp"/>

                        <!-- 4. Diabetes -->
                        <View android:id="@+id/tickDiabetes" android:layout_width="6dp" android:layout_height="1dp" android:background="#666666" app:layout_constraintBottom_toBottomOf="@id/barDiabetes" app:layout_constraintEnd_toEndOf="@id/guideSolidLine" app:layout_constraintTop_toTopOf="@id/barDiabetes" />
                        <TextView
                            android:id="@+id/labelDiabetes"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="10dp"
                            android:gravity="end"
                            android:text="Diabetes"
                            android:textColor="#666666"
                            android:textSize="12sp"
                            app:layout_constraintBottom_toBottomOf="@+id/barDiabetes"
                            app:layout_constraintEnd_toStartOf="@id/tickDiabetes"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="@+id/barDiabetes" />
                        <View
                            android:id="@+id/barDiabetes"
                            android:layout_width="0dp"
                            android:layout_height="40dp"
                            android:layout_marginTop="12dp"
                            android:background="#1976D2"
                            app:layout_constraintEnd_toStartOf="@id/guideBase"
                            app:layout_constraintStart_toStartOf="@id/guideBase"
                            app:layout_constraintTop_toBottomOf="@id/barSmoking"
                            android:layout_marginStart="-25dp"/>

                        <!-- 5. Activity -->
                        <View android:id="@+id/tickActivity" android:layout_width="6dp" android:layout_height="1dp" android:background="#666666" app:layout_constraintBottom_toBottomOf="@id/barActivity" app:layout_constraintEnd_toEndOf="@id/guideSolidLine" app:layout_constraintTop_toTopOf="@id/barActivity" />
                        <TextView
                            android:id="@+id/labelActivity"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="10dp"
                            android:gravity="end"
                            android:text="Activity"
                            android:textColor="#666666"
                            android:textSize="12sp"
                            app:layout_constraintBottom_toBottomOf="@+id/barActivity"
                            app:layout_constraintEnd_toStartOf="@id/tickActivity"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="@+id/barActivity" />
                        <View
                            android:id="@+id/barActivity"
                            android:layout_width="0dp"
                            android:layout_height="40dp"
                            android:layout_marginTop="12dp"
                            android:background="#1976D2"
                            app:layout_constraintStart_toStartOf="@id/guideBase"
                            app:layout_constraintEnd_toEndOf="@id/guideBase"
                            app:layout_constraintTop_toBottomOf="@id/barDiabetes"
                            android:layout_marginEnd="-32dp"/>

                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:paddingHorizontal="32dp"
                        android:paddingBottom="32dp"
                        android:text="Positive values increase health probability. Negative values decrease it."
                        android:textColor="#666666"
                        android:textSize="12sp"
                        android:lineSpacingExtra="4dp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Bottom Action Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnModelConfidence"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="40dp"
                android:text="Model Confidence"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                app:backgroundTint="#2563EB"
                app:cornerRadius="12dp"
                app:layout_constraintTop_toBottomOf="@id/cardChart" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
